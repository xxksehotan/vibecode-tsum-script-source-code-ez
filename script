local function cleanName(orig)
    if not orig or orig == "" then return orig end

    -- 1) собираем латиницу (бренды/EN-слова)
    local latinWords = {}
    for w in orig:gmatch("[A-Za-z][A-Za-z%-%.'0-9]*") do
        if #w >= 2 then table.insert(latinWords, w) end
    end
    local latinPart = table.concat(latinWords, " ")

    local lower = orig:lower()

    -- 2) категория
    local category
    for ru, en in pairs(CATEGORY) do
        if lower:find(ru, 1, true) then category = en; break end
    end

    -- 3) цвет
    local color
    for ru, en in pairs(COLOR) do
        if lower:find(ru, 1, true) then color = en; break end
    end

    -- 4) собираем точное имя
    if latinPart ~= "" then
        local result = latinPart
        local lowerLatin = latinPart:lower()
        if category and not lowerLatin:find(category:lower(), 1, true) then
            result = result .. " " .. category
        end
        if color and not result:lower():find(color:lower(), 1, true) then
            result = result .. " " .. color
        end
        return result
    elseif category then
        return color and (color .. " " .. category) or category
    end
    return orig
end

-- ═══════════════════════════════════════════════════
--   NAME CACHE
-- ═══════════════════════════════════════════════════
local nameCache = {}      -- [id] = cleaned name | "PENDING" | "FAIL"
local rawNameCache = {}   -- [id] = original (для дебага)
local fetchQueue = {}
local fetching = false

local function processQueue()
    if fetching then return end
    fetching = true
    task.spawn(function()
        while #fetchQueue > 0 do
            local id = table.remove(fetchQueue, 1)
            if nameCache[id] == "PENDING" then
                local ok, info = pcall(function()
                    return MS:GetProductInfo(tonumber(id), Enum.InfoType.Asset)
                end)
                if ok and info and info.Name then
                    rawNameCache[id] = info.Name
                    nameCache[id] = cleanName(info.Name)
                else
                    nameCache[id] = "FAIL"
                end
                task.wait(0.15)
            end
        end
        fetching = false
    end)
end

local function requestName(id)
    if not id then return nil end
    if nameCache[id] and nameCache[id] ~= "PENDING" and nameCache[id] ~= "FAIL" then
        return nameCache[id]
    end
    if not nameCache[id] then
        nameCache[id] = "PENDING"
        table.insert(fetchQueue, id)
        processQueue()
    end
    return nil
end

-- ═══════════════════════════════════════════════════
local ESP = {
    enabled = false,
    rarities = { Legendary=true, Epic=false, Rare=false, Uncommon=false, Common=false },
    showRarity = true, showName = true, showRaw = false, showAssetId = false, showDistance = true,
    cleanNames = true,
    textSize = 16, useTextScaled = false,
    maxDistance = 500, scanInterval = 2,
    useRarityColor = true,
    nameFilterEnabled = false,
}

local nameFilters = {}
local activeESP = {}

local function getSlotData(slot)
    local rarity = nil
    for _, d in ipairs(slot:GetDescendants()) do
        if d:IsA("Highlight") then
            for rn, rc in pairs(rarityColors) do
                if close(d.FillColor, rc) then rarity = rn; break end
            end
            break
        end
    end
    if not rarity then return nil end
    local mainId = nil
    for _, d in ipairs(slot:GetDescendants()) do
        local tmpl
        if d:IsA("Shirt") then tmpl = d.ShirtTemplate
        elseif d:IsA("Pants") then tmpl = d.PantsTemplate end
        if tmpl and tmpl ~= "" then
            local id = tmpl:match("%d+")
            if id then mainId = id; break end
        end
    end
    return { rarity = rarity, assetId = mainId }
end

local function getCurrentName(data)
    if not data.assetId then return nil end
    local cached = ESP.cleanNames and nameCache[data.assetId] or rawNameCache[data.assetId]
    if cached and cached ~= "PENDING" and cached ~= "FAIL" then return cached end
    return nil
end

local function shouldShow(data)
    if not ESP.rarities[data.rarity] then return false end
    if ESP.nameFilterEnabled and #nameFilters > 0 then
        local name = getCurrentName(data)
        if not name then return false end
        local lname = name:lower()
        for _, f in ipairs(nameFilters) do
            if lname:find(f, 1, true) then return true end
        end
        return false
    end
    return true
end

local function getAdornee(slot)
    local m = slot:FindFirstChild("Mannequin")
    if m then
        local p = m.PrimaryPart or m:FindFirstChild("Torso") or m:FindFirstChildWhichIsA("BasePart")
        return m, p or slot
    end
    return slot, slot
end

local function getDist(part)
    local hrp = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
    if not hrp or not part then return 9999 end
    local ok, pos = pcall(function() return part.Position end)
    if not ok then return 9999 end
    return (hrp.Position - pos).Magnitude
end

local function addESP(slot, data)
    if activeESP[slot] then return end
    if data.assetId then requestName(data.assetId) end
    local adornee, pivot = getAdornee(slot)
    local color = ESP.useRarityColor and (rarityColors[data.rarity] or Color3.fromRGB(255,200,0)) or Color3.fromRGB(255,200,0)

    local hl = Instance.new("Highlight")
    hl.Adornee = adornee; hl.FillColor = color
    hl.OutlineColor = Color3.fromRGB(255,255,255); hl.FillTransparency = 0.4
    hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop; hl.Parent = adornee

    local bb = Instance.new("BillboardGui")
    bb.Adornee = pivot; bb.Size = UDim2.new(0,340,0,55)
    bb.StudsOffset = Vector3.new(0,4,0); bb.AlwaysOnTop = true
    bb.MaxDistance = ESP.maxDistance; bb.Parent = pivot

    local lbl = Instance.new("TextLabel")
    lbl.BackgroundTransparency = 1; lbl.Size = UDim2.fromScale(1,1)
    lbl.TextColor3 = color; lbl.TextStrokeTransparency = 0
    lbl.Font = Enum.Font.GothamBold; lbl.Parent = bb

    activeESP[slot] = { hl=hl, bb=bb, lbl=lbl, data=data, pivot=pivot }
end

local function removeESP(slot)
    local d = activeESP[slot]; if not d then return end
    if d.hl then d.hl:Destroy() end
    if d.bb then d.bb:Destroy() end
    activeESP[slot] = nil
end
local function clearAll() for s in pairs(activeESP) do removeESP(s) end end

local function getAllSlots()
    local r = {}
    for _, c in ipairs(workspace:GetChildren()) do
        if c.Name:find("^Shop_") then
            local is = c:FindFirstChild("ItemSlots")
            if is then for _, s in ipairs(is:GetChildren()) do table.insert(r,s) end end
            local as = c:FindFirstChild("AccessorySlots")
            if as then for _, s in ipairs(as:GetChildren()) do table.insert(r,s) end end
        end
    end
    return r
end

local function refreshActive()
    for slot, e in pairs(activeESP) do
        if not shouldShow(e.data) then removeESP(slot) end
    end
end

local function scan()
    for _, slot in ipairs(getAllSlots()) do
        local d = getSlotData(slot)
        if d and ESP.rarities[d.rarity] then
            if d.assetId then requestName(d.assetId) end
            if shouldShow(d) and not activeESP[slot] then
                local _, p = getAdornee(slot)
                if getDist(p) < ESP.maxDistance then addESP(slot, d) end
            elseif not shouldShow(d) and activeESP[slot] then removeESP(slot) end
        elseif activeESP[slot] then removeESP(slot) end
    end
    for slot, esp in pairs(activeESP) do
        if not slot.Parent then removeESP(slot)
        elseif getDist(esp.pivot) > ESP.maxDistance * 1.2 then removeESP(slot) end
    end
end

local function start()
    task.spawn(function()
        local hits = 0
        for i, slot in ipairs(getAllSlots()) do
            if not ESP.enabled then break end
            local d = getSlotData(slot)
            if d and ESP.rarities[d.rarity] then
                if d.assetId then requestName(d.assetId) end
                if shouldShow(d) then addESP(slot, d); hits = hits + 1 end
            end
            if i % 60 == 0 then task.wait() end
        end
        print("[detroit.lol] Подсвечено: " .. hits)
    end)
    task.spawn(function() while ESP.enabled do pcall(scan); task.wait(ESP.scanInterval) end end)
    task.spawn(function()
        while ESP.enabled do
            for slot, e in pairs(activeESP) do
                if slot.Parent and e.pivot then
                    local parts = {}
                    if ESP.showRarity then table.insert(parts, "[" .. e.data.rarity .. "]") end
                    if ESP.showName then
                        local raw = e.data.assetId and rawNameCache[e.data.assetId]
                        local clean = e.data.assetId and nameCache[e.data.assetId]
                        if clean == "PENDING" or clean == nil then table.insert(parts, "...")
                        elseif clean == "FAIL" then table.insert(parts, "?")
                        else
                            if ESP.cleanNames then
                                table.insert(parts, clean)
                                if ESP.showRaw and raw and raw ~= clean then
                                    table.insert(parts, "(" .. raw .. ")")
                                end
                            else
                                table.insert(parts, raw or clean)
                            end
                        end
                    end
                    if ESP.showAssetId and e.data.assetId then table.insert(parts, "#"..e.data.assetId) end
                    if ESP.showDistance then table.insert(parts, math.floor(getDist(e.pivot)) .. "m") end
                    e.lbl.Text = table.concat(parts, " ")
                    if ESP.useTextScaled then e.lbl.TextScaled = true
                    else e.lbl.TextScaled = false; e.lbl.TextSize = ESP.textSize end
                    e.bb.MaxDistance = ESP.maxDistance
                end
            end
            if ESP.nameFilterEnabled then
                for slot, e in pairs(activeESP) do
                    if not shouldShow(e.data) then removeESP(slot) end
                end
            end
            task.wait(0.3)
        end
    end)
end
local function stop() ESP.enabled = false; clearAll() end

