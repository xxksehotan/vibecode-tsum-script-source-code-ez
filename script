local RS = game:GetService("ReplicatedStorage")
local LP = game:GetService("Players").LocalPlayer
local MS = game:GetService("MarketplaceService")

local config = require(RS:WaitForChild("ClothingConfig"))
local rarityColors = {}
for rn, rd in pairs(config.RARITIES or {}) do
    if type(rd)=="table" and rd.color then
        local c = rd.color
        if typeof(c)=="Color3" then rarityColors[rn]=c
        elseif type(c)=="table" then rarityColors[rn]=Color3.new(c[1] or 0,c[2] or 0,c[3] or 0) end
    end
end
local function close(a,b) return math.abs(a.R-b.R)<0.05 and math.abs(a.G-b.G)<0.05 and math.abs(a.B-b.B)<0.05 end

